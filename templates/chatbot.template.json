    {
      "parameters": {
        "jsCode": "// n8n Code node\nreturn items.map(item => {\n  // Ajuste para tu estructura actual (viene en body.phone)\n  const rawPhone = item.json?.body?.phone ?? item.json?.phone ?? '';\n\n  // Convertir a string y limpiar espacios extremos\n  let phone = String(rawPhone).trim();\n\n  // Quitar todo excepto dígitos y \"+\"\n  // (ej: \"+52 155-3523(0764)\" -> \"+5215535230764\")\n  phone = phone.replace(/[^\\d+]/g, '');\n\n  // Si hay más de un \"+\", dejar solo el primero al inicio\n  if ((phone.match(/\\+/g) || []).length > 1) {\n    phone = '+' + phone.replace(/\\+/g, '');\n  }\n\n  // Si el \"+\" quedó en el medio, moverlo al inicio\n  if (phone.includes('+') && !phone.startsWith('+')) {\n    phone = '+' + phone.replace(/\\+/g, '');\n  }\n\n  // OPCIONAL:\n  // Si no viene con +, agregárselo automáticamente\n  if (phone && !phone.startsWith('+')) {\n    phone = '+' + phone;\n  }\n\n  // Guardar valor normalizado en un campo nuevo\n  item.json.normalizedPhone = phone;\n\n  // Si querés también pisar el original del body:\n  if (item.json.body && item.json.body.phone) {\n    item.json.body.phone = phone;\n  }\n\n  return item;\n});"
      },
