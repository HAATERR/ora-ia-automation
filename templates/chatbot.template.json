    {
      "parameters": {
        "jsCode": "const rawOutput = $json.output ?? '';\n\nlet parsed = {};\nlet msg = String(rawOutput);\n\ntry {\n  const cleaned = String(rawOutput)\n    .trim()\n    .replace(/^```json\\s*/i, '')\n    .replace(/```$/i, '');\n\n  parsed = JSON.parse(cleaned);\n  msg = parsed.message ?? msg;\n} catch (e) {\n  parsed = {};\n}\n\nconst safeMessage = String(msg)\n  .replace(/\\\\/g, '\\\\\\\\')\n  .replace(/\\r?\\n/g, '\\\\n')\n  .replace(/\\t/g, '\\\\t')\n  .replace(/\"/g, '\\\\\"');\n\nlet contactId = '';\n\ntry {\n  contactId = $('HTTP Request1').first().json.contacts?.[0]?.id || '';\n} catch (e) {}\n\ntry {\n  contactId = contactId || $('HTTP Request2').first().json.contact?.id || $('HTTP Request2').first().json.id || '';\n} catch (e) {}\n\nconst startTime =\n  parsed.startTime ??\n  parsed.start_time ??\n  $json.startTime ??\n  $json.start_time ??\n  '';\n\nconst endTime =\n  parsed.endTime ??\n  parsed.end_time ??\n  $json.endTime ??\n  $json.end_time ??\n  '';\n\nreturn [\n  {\n    json: {\n      ...$json,\n      safeMessage,\n      contactId,\n      calendarId: \"6Lb3KSeoJqjXAmXkAU99\",\n      locationId: \"Hp6PghlkNYxLuOCVOgUx\",\n      startTime,\n      endTime\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
