    {
      "name": "Eval 2",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const c = $json.contact ?? $json;\nconst tags = (c.tags || []).map(t => String(t).toLowerCase());\nreturn [{ json: { contactId: c.id, phone: c.phone, answered: tags.includes('answered') } }];"
      },
      "id": "n4",
