    {
      "name": "Parse Label",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const ch = $input.first().json.choices; const content = (ch && ch[0] && ch[0].message && ch[0].message.content) || '';\nlet label = String(content).toLowerCase().replace(/[\"'.]/g, '').trim();\nconst valid = [\"whatsapp\",\"llamada ia\",\"seguimiento manual\"];\nif (!valid.includes(label)) label = \"seguimiento manual\";\nreturn [{ json: { label, classifyRaw: content } }];"
      },
