    {
      "name": "Normalizar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const b = $input.first().json.body ?? $input.first().json;\nconst tags = Array.isArray(b.tags) ? b.tags.map(t => String(t).toLowerCase()) : (b.tags ? [String(b.tags).toLowerCase()] : []);\nlet tag = 'answered';\nif (tags.includes('dnc')) tag = 'dnc'; else if (tags.includes('dna')) tag = 'dna'; else if (tags.includes('answered')) tag = 'answered';\nreturn [{ json: { toNumber: b.to_number ?? null, fromNumber: b.from_number ?? null, transcript: b.transcript ?? '', recordingLink: b.recording_link ?? '', callDuration: b.call_duration ?? '', appointment: b.appointment ?? '', tag, tagsRaw: tags } }];"
      },
      "id": "n2",
      "position": [
        420,
        400
      ]
    },
    {
      "name": "GHL · Find Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "parameters": {
        "method": "POST",
        "url": "https://services.leadconnectorhq.com/contacts/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ORA_PIT}}"
            },
            {
              "name": "Version",
              "value": "2021-07-28"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ locationId: \"{{ORA_LOCATION_ID}}\", pageLimit: 1, filters: [ { field: \"phone\", operator: \"eq\", value: $('Normalizar').item.json.toNumber } ] }) }}",
        "options": {}
      },
      "id": "n3",
      "position": [
        620,
        400
      ]
    },
    {
      "name": "Contacto",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const c = ($input.first().json.contacts && $input.first().json.contacts[0]) || null;\nconst n = $('Normalizar').item.json;\nreturn [{ json: { ...n, contactId: c ? c.id : '', found: !!c, contactName: c ? ((c.firstName || '') + ' ' + (c.lastName || '')).trim() : '' } }];"
      },
      "id": "n4",
      "position": [
        820,
        400
      ]
