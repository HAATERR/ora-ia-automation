# Variables de entorno de la app web (Vercel: Project Settings → Environment Variables).
# Para desarrollo local copiá este archivo a web/.env.local y completá los valores.
# NINGUNA lleva prefijo NEXT_PUBLIC_ → son server-only (no se mandan al browser).

# Claude (para /api/extract: imagen del flujograma → flow-spec)
ANTHROPIC_API_KEY=

# n8n Public API (para /api/provision)
N8N_BASE_URL=https://oraia.up.railway.app
N8N_API_KEY=

# Gate de acceso (password compartida de los devs de Ora IA) — se usa en el paso 6.
APP_PASSWORD=
