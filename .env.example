# ── n8n Public API ───────────────────────────────────────────────
# Base de tu instancia (sin /api/v1; el cliente lo agrega solo)
N8N_BASE_URL=https://n8n.tu-dominio.com
# Settings → n8n API → Create an API key  (se manda como header X-N8N-API-KEY)
N8N_API_KEY=

# ── Claude API (para extract-flow: imagen del flujograma → flow-spec) ──
ANTHROPIC_API_KEY=

# ── GoHighLevel API v2 (defaults, normalmente no se tocan) ────────
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
